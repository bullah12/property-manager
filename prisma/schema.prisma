// Prisma mirrors the SQL migrations in db/migrations/ (the contract).
// After adding a migration, run `npm run db:migrate`, then keep these models
// in sync by hand (annotations like @updatedAt live only here).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- 0004_files_and_contracts ----

model File {
  id                        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId               String              @map("workspace_id") @db.Uuid
  ownerId                   String?             @map("owner_id") @db.Uuid
  purpose                   String
  storageKey                String              @unique @map("storage_key")
  contentType               String              @map("content_type")
  sizeBytes                 BigInt              @map("size_bytes")
  checksumSha256            String?             @map("checksum_sha256")
  isPublic                  Boolean             @default(false) @map("is_public")
  status                    String              @default("pending")
  variants                  Json                @default("{}")
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  owner                     User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspace                 Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contracts                 Contract[]
  transactions              Transaction[]
  complianceItems           ComplianceItem[]
  generatedDocuments        GeneratedDocument[]
  ownershipEventDocuments   OwnershipEvent[]    @relation("OwnershipEventDocument")
  ownershipPaymentDocuments OwnershipPayment[]  @relation("OwnershipPaymentDocument")
  ownershipNoteDocuments    OwnershipNote[]     @relation("OwnershipNoteDocument")
  propertyValuationEvidence PropertyValuation[] @relation("PropertyValuationEvidence")

  @@unique([id, workspaceId], map: "uq_files_id_workspace")
  @@index([ownerId], map: "idx_files_owner_id")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_files_workspace")
  @@map("files")
}

model Contract {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId         String             @map("workspace_id") @db.Uuid
  tenancyId           String             @map("tenancy_id") @db.Uuid
  kind                String
  source              String
  fileId              String             @map("file_id") @db.Uuid
  generatedDocumentId String?            @map("generated_document_id") @db.Uuid
  signedOn            DateTime?          @map("signed_on") @db.Date
  status              String             @default("draft")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenancy             Tenancy            @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  file                File               @relation(fields: [fileId], references: [id], onDelete: Restrict)
  generatedDocument   GeneratedDocument? @relation(fields: [generatedDocumentId], references: [id], onDelete: SetNull, map: "fk_contracts_generated_document_id")
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenancyId], map: "idx_contracts_tenancy_id")
  @@index([fileId], map: "idx_contracts_file_id")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_contracts_workspace")
  @@map("contracts")
}

// ---- 0001_users_and_settings ----

model User {
  id                      String                @id @db.Uuid
  email                   String                @unique @db.Citext
  displayName             String                @map("display_name")
  role                    String                @default("admin")
  status                  String                @default("active")
  timezone                String                @default("Europe/London")
  createdAt               DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  settings                UserSettings?
  files                   File[]
  notifications           Notification[]
  workspaceMemberships    WorkspaceMembership[]
  recordedOwnershipEvents OwnershipEvent[]      @relation("OwnershipEventRecorder")
  authoredOwnershipNotes  OwnershipNote[]       @relation("OwnershipNoteAuthor")
  createdInvestmentEntries OwnerInvestmentEntry[] @relation("InvestmentEntryCreator")

  @@map("users")
}

// ---- 0016_workspaces_and_data_isolation ----

model Workspace {
  id                        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String
  status                    String                     @default("active")
  createdAt                 DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships               WorkspaceMembership[]
  properties                Property[]
  tenants                   Tenant[]
  tenancies                 Tenancy[]
  transactions              Transaction[]
  complianceItems           ComplianceItem[]
  reminders                 Reminder[]
  files                     File[]
  contracts                 Contract[]
  generatedDocuments        GeneratedDocument[]
  contractors               Contractor[]
  contractorReviews         ContractorReview[]
  notifications             Notification[]
  jobs                      Job[]
  owners                    Owner[]
  ownershipEvents           OwnershipEvent[]
  ownershipPayments         OwnershipPayment[]
  ownershipNotes            OwnershipNote[]
  ownershipEventAllocations OwnershipEventAllocation[]
  acquisitionCosts          AcquisitionCost[]
  ownerInvestmentEntries    OwnerInvestmentEntry[]
  propertyLoans             PropertyLoan[]
  loanEvents                LoanEvent[]
  propertyValuations        PropertyValuation[]
  investmentForecasts       InvestmentForecast[]
  plannedInvestmentCosts    PlannedInvestmentCost[]

  @@map("workspaces")
}

model WorkspaceMembership {
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        String    @default("member")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId, status], map: "idx_workspace_memberships_user")
  @@map("workspace_memberships")
}

// ---- 0002_properties ----

model Property {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String   @map("workspace_id") @db.Uuid
  nickname           String
  addressLine1       String   @map("address_line1")
  addressLine2       String?  @map("address_line2")
  city               String
  postcode           String
  propertyType       String   @map("property_type")
  bedrooms           Int?
  purchasePriceCents Int?     @map("purchase_price_cents")
  purchaseCompletionDate DateTime? @map("purchase_completion_date") @db.Date
  notes              String?
  status             String   @default("active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenancies         Tenancy[]
  transactions      Transaction[]
  complianceItems   ComplianceItem[]
  ownershipEvents   OwnershipEvent[]
  ownershipPayments OwnershipPayment[]
  ownershipNotes    OwnershipNote[]
  acquisitionCosts  AcquisitionCost[]
  ownerInvestmentEntries OwnerInvestmentEntry[]
  loans             PropertyLoan[]
  valuations        PropertyValuation[]
  investmentForecast InvestmentForecast?
  plannedInvestmentCosts PlannedInvestmentCost[]
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], map: "uq_properties_id_workspace")
  @@index([status], map: "idx_properties_status")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_properties_workspace")
  @@map("properties")
}

// ---- 0017_shared_property_ownership ----

model Owner {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  fullName    String   @map("full_name")
  address     String
  phone       String?
  email       String?  @db.Citext
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace        Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventAllocations OwnershipEventAllocation[]
  soldEvents       OwnershipEvent[]           @relation("OwnershipEventSeller")
  boughtEvents     OwnershipEvent[]           @relation("OwnershipEventBuyer")
  paymentsMade     OwnershipPayment[]         @relation("OwnershipPaymentPayer")
  paymentsReceived OwnershipPayment[]         @relation("OwnershipPaymentRecipient")
  ownershipNotes   OwnershipNote[]
  acquisitionCosts AcquisitionCost[]
  investmentEntries OwnerInvestmentEntry[]

  @@unique([id, workspaceId], map: "uq_owners_id_workspace")
  @@index([workspaceId, fullName], map: "idx_owners_workspace_name")
  @@map("owners")
}

// ---- 0018_historical_ownership_ledger ----

model OwnershipEvent {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId               String    @map("workspace_id") @db.Uuid
  propertyId                String    @map("property_id") @db.Uuid
  eventType                 String    @map("event_type")
  transferType              String?   @map("transfer_type")
  effectiveDate             DateTime  @map("effective_date") @db.Date
  legalCompletionDate       DateTime? @map("legal_completion_date") @db.Date
  recordedAt                DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  recordedByUserId          String?   @map("recorded_by_user_id") @db.Uuid
  sellerOwnerId             String?   @map("seller_owner_id") @db.Uuid
  buyerOwnerId              String?   @map("buyer_owner_id") @db.Uuid
  percentageTransferred     Decimal?  @map("percentage_transferred") @db.Decimal(5, 2)
  agreedValueCents          BigInt?   @map("agreed_value_cents")
  currency                  String    @default("GBP") @db.VarChar(3)
  paymentTreatment          String?   @map("payment_treatment")
  effectiveAfterFullPayment Boolean   @default(false) @map("effective_after_full_payment")
  beforeSnapshot            Json      @default("[]") @map("before_snapshot")
  afterSnapshot             Json      @default("[]") @map("after_snapshot")
  reason                    String?
  notes                     String?
  reversesEventId           String?   @map("reverses_event_id") @db.Uuid
  documentFileId            String?   @map("document_file_id") @db.Uuid
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace      Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property       Property                   @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  recordedBy     User?                      @relation("OwnershipEventRecorder", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  seller         Owner?                     @relation("OwnershipEventSeller", fields: [sellerOwnerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  buyer          Owner?                     @relation("OwnershipEventBuyer", fields: [buyerOwnerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  allocations    OwnershipEventAllocation[]
  payments       OwnershipPayment[]
  ownershipNotes OwnershipNote[]
  reversesEvent  OwnershipEvent?            @relation("OwnershipEventReversal", fields: [reversesEventId], references: [id], onDelete: Restrict)
  reversedBy     OwnershipEvent[]           @relation("OwnershipEventReversal")
  documentFile   File?                      @relation("OwnershipEventDocument", fields: [documentFileId, workspaceId], references: [id, workspaceId], onDelete: NoAction)

  @@unique([id, workspaceId], map: "uq_ownership_events_id_workspace")
  @@index([workspaceId, propertyId, effectiveDate(sort: Desc), recordedAt(sort: Desc)], map: "idx_ownership_events_property_date")
  @@map("ownership_events")
}

model OwnershipEventAllocation {
  eventId             String  @map("event_id") @db.Uuid
  workspaceId         String  @map("workspace_id") @db.Uuid
  ownerId             String  @map("owner_id") @db.Uuid
  ownershipPercentage Decimal @map("ownership_percentage") @db.Decimal(5, 2)
  isMainLandlord      Boolean @default(false) @map("is_main_landlord")

  event     OwnershipEvent @relation(fields: [eventId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  owner     Owner          @relation(fields: [ownerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([eventId, ownerId])
  @@index([workspaceId, ownerId], map: "idx_ownership_event_allocations_owner")
  @@map("ownership_event_allocations")
}

model OwnershipPayment {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId           String    @map("workspace_id") @db.Uuid
  propertyId            String    @map("property_id") @db.Uuid
  eventId               String?   @map("event_id") @db.Uuid
  kind                  String
  payerOwnerId          String?   @map("payer_owner_id") @db.Uuid
  recipientOwnerId      String?   @map("recipient_owner_id") @db.Uuid
  amountDueCents        BigInt    @map("amount_due_cents")
  amountPaidCents       BigInt    @default(0) @map("amount_paid_cents")
  currency              String    @default("GBP") @db.VarChar(3)
  dueOn                 DateTime? @map("due_on") @db.Date
  paidOn                DateTime? @map("paid_on") @db.Date
  status                String    @default("scheduled")
  paymentMethod         String?   @map("payment_method")
  reference             String?
  throughPropertyFunds  Boolean   @default(false) @map("through_property_funds")
  propertyFundDirection String?   @map("property_fund_direction")
  allowOverpayment      Boolean   @default(false) @map("allow_overpayment")
  notes                 String?
  documentFileId        String?   @map("document_file_id") @db.Uuid
  transactionId         String?   @unique @map("transaction_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property       Property        @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  event          OwnershipEvent? @relation(fields: [eventId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  payer          Owner?          @relation("OwnershipPaymentPayer", fields: [payerOwnerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  recipient      Owner?          @relation("OwnershipPaymentRecipient", fields: [recipientOwnerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  documentFile   File?           @relation("OwnershipPaymentDocument", fields: [documentFileId, workspaceId], references: [id, workspaceId], onDelete: NoAction)
  transaction    Transaction?    @relation(fields: [transactionId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  ownershipNotes OwnershipNote[]

  @@unique([id, workspaceId], map: "uq_ownership_payments_id_workspace")
  @@unique([transactionId, workspaceId], map: "uq_ownership_payments_transaction_workspace")
  @@index([workspaceId, propertyId, dueOn], map: "idx_ownership_payments_property_due")
  @@map("ownership_payments")
}

model OwnershipNote {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  propertyId     String    @map("property_id") @db.Uuid
  ownerId        String?   @map("owner_id") @db.Uuid
  eventId        String?   @map("event_id") @db.Uuid
  paymentId      String?   @map("payment_id") @db.Uuid
  title          String
  noteText       String    @map("note_text")
  noteDate       DateTime  @map("note_date") @db.Date
  authorUserId   String?   @map("author_user_id") @db.Uuid
  sensitivity    String    @default("workspace")
  reviewOn       DateTime? @map("review_on") @db.Date
  documentFileId String?   @map("document_file_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property     Property          @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  owner        Owner?            @relation(fields: [ownerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  event        OwnershipEvent?   @relation(fields: [eventId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  payment      OwnershipPayment? @relation(fields: [paymentId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  author       User?             @relation("OwnershipNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  documentFile File?             @relation("OwnershipNoteDocument", fields: [documentFileId, workspaceId], references: [id, workspaceId], onDelete: NoAction)

  @@index([workspaceId, propertyId, noteDate(sort: Desc)], map: "idx_ownership_notes_property_date")
  @@map("ownership_notes")
}

// ---- 0019_investment_performance ----

model AcquisitionCost {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  propertyId    String   @map("property_id") @db.Uuid
  category      String
  amountCents   BigInt   @map("amount_cents")
  occurredOn    DateTime @map("occurred_on") @db.Date
  fundingSource String   @map("funding_source")
  ownerId       String?  @map("owner_id") @db.Uuid
  description   String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  owner         Owner? @relation(fields: [ownerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)

  @@unique([id, workspaceId])
  @@index([workspaceId, propertyId, occurredOn], map: "idx_acquisition_costs_workspace_property_date")
  @@map("acquisition_costs")
}

model OwnerInvestmentEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  entryType   String   @map("entry_type")
  amountCents BigInt   @map("amount_cents")
  occurredOn  DateTime @map("occurred_on") @db.Date
  description String?
  reason      String?
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  owner       Owner @relation(fields: [ownerId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  creator     User? @relation("InvestmentEntryCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([id, workspaceId])
  @@index([workspaceId, propertyId, occurredOn], map: "idx_owner_investment_workspace_property_date")
  @@index([workspaceId, ownerId, occurredOn], map: "idx_owner_investment_workspace_owner_date")
  @@map("owner_investment_entries")
}

model PropertyLoan {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId          String   @map("workspace_id") @db.Uuid
  propertyId           String   @map("property_id") @db.Uuid
  lender               String?
  name                 String
  originalBalanceCents BigInt   @map("original_balance_cents")
  openingBalanceCents  BigInt   @map("opening_balance_cents")
  interestRateBps      Int?     @map("interest_rate_bps")
  repaymentType        String   @map("repayment_type")
  monthlyPaymentCents  BigInt?  @map("monthly_payment_cents")
  startedOn            DateTime @map("started_on") @db.Date
  endsOn               DateTime? @map("ends_on") @db.Date
  secured              Boolean  @default(true)
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property             Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  events               LoanEvent[]

  @@unique([id, workspaceId])
  @@index([workspaceId, propertyId], map: "idx_property_loans_workspace_property")
  @@map("property_loans")
}

model LoanEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  loanId      String   @map("loan_id") @db.Uuid
  eventType   String   @map("event_type")
  amountCents BigInt   @map("amount_cents")
  occurredOn  DateTime @map("occurred_on") @db.Date
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  loan        PropertyLoan @relation(fields: [loanId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@index([workspaceId, loanId, occurredOn], map: "idx_loan_events_workspace_loan_date")
  @@map("loan_events")
}

model PropertyValuation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  propertyId     String   @map("property_id") @db.Uuid
  valueCents     BigInt   @map("value_cents")
  valuedOn       DateTime @map("valued_on") @db.Date
  source         String
  notes          String?
  evidenceFileId String?  @map("evidence_file_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  evidenceFile   File? @relation("PropertyValuationEvidence", fields: [evidenceFileId, workspaceId], references: [id, workspaceId], onDelete: NoAction)

  @@unique([id, workspaceId])
  @@index([workspaceId, propertyId, valuedOn(sort: Desc)], map: "idx_property_valuations_workspace_property_date")
  @@map("property_valuations")
}

model InvestmentForecast {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId              String   @map("workspace_id") @db.Uuid
  propertyId               String   @map("property_id") @db.Uuid
  expectedMonthlyRentCents BigInt?  @map("expected_monthly_rent_cents")
  rentGrowthBps            Int?     @map("rent_growth_bps")
  occupancyBps             Int?     @map("occupancy_bps")
  expenseInflationBps      Int?     @map("expense_inflation_bps")
  appreciationBps          Int?     @map("appreciation_bps")
  mortgageInterestBps      Int?     @map("mortgage_interest_bps")
  monthlyRepaymentCents    BigInt?  @map("monthly_repayment_cents")
  horizonMonths            Int      @default(60) @map("horizon_months")
  targetReturnBps          Int?     @map("target_return_bps")
  targetRecoveryDate       DateTime? @map("target_recovery_date") @db.Date
  targetLtvBps             Int?     @map("target_ltv_bps")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace                Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property                 Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([propertyId, workspaceId])
  @@unique([id, workspaceId])
  @@map("investment_forecasts")
}

model PlannedInvestmentCost {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  category    String
  amountCents BigInt   @map("amount_cents")
  plannedOn   DateTime @map("planned_on") @db.Date
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId, workspaceId], references: [id, workspaceId], onDelete: Cascade)

  @@unique([id, workspaceId])
  @@index([workspaceId, propertyId, plannedOn], map: "idx_planned_costs_workspace_property_date")
  @@map("planned_investment_costs")
}

// ---- 0003_tenants_tenancies ----

model Tenant {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  fullName    String    @map("full_name")
  email       String?   @db.Citext
  phone       String?
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenancies   Tenancy[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], map: "uq_tenants_id_workspace")
  @@index([email], map: "idx_tenants_email")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_tenants_workspace")
  @@map("tenants")
}

model Tenancy {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String        @map("workspace_id") @db.Uuid
  propertyId         String        @map("property_id") @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  startDate          DateTime      @map("start_date") @db.Date
  endDate            DateTime?     @map("end_date") @db.Date
  endedOn            DateTime?     @map("ended_on") @db.Date
  rentAmountCents    Int           @map("rent_amount_cents")
  rentDueDay         Int           @map("rent_due_day")
  depositAmountCents Int?          @map("deposit_amount_cents")
  depositScheme      String?       @map("deposit_scheme")
  depositReference   String?       @map("deposit_reference")
  status             String        @default("draft")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  property           Property      @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contracts          Contract[]
  transactions       Transaction[]
  workspace          Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], map: "uq_tenancies_id_workspace")
  @@index([propertyId, status], map: "idx_tenancies_property_id_status")
  @@index([tenantId], map: "idx_tenancies_tenant_id")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_tenancies_workspace")
  @@map("tenancies")
}

// ---- 0005_transactions ----

model Transaction {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String            @map("workspace_id") @db.Uuid
  propertyId       String            @map("property_id") @db.Uuid
  tenancyId        String?           @map("tenancy_id") @db.Uuid
  direction        String
  category         String
  amountCents      Int               @map("amount_cents")
  occurredOn       DateTime          @map("occurred_on") @db.Date
  description      String?
  receiptFileId    String?           @map("receipt_file_id") @db.Uuid
  rentPeriod       DateTime?         @map("rent_period") @db.Date
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenancy          Tenancy?          @relation(fields: [tenancyId], references: [id], onDelete: SetNull)
  receiptFile      File?             @relation(fields: [receiptFileId], references: [id], onDelete: SetNull)
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownershipPayment OwnershipPayment?

  @@unique([id, workspaceId], map: "uq_transactions_id_workspace")
  @@index([propertyId, occurredOn(sort: Desc)], map: "idx_transactions_property_id_occurred_on")
  @@index([tenancyId, rentPeriod], map: "idx_transactions_tenancy_id_rent_period")
  @@index([receiptFileId], map: "idx_transactions_receipt_file_id")
  @@index([workspaceId, occurredOn(sort: Desc)], map: "idx_transactions_workspace")
  @@map("transactions")
}

// ---- 0006_compliance_and_reminders ----

model ComplianceItem {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  propertyId       String    @map("property_id") @db.Uuid
  kind             String
  label            String
  dueOn            DateTime  @map("due_on") @db.Date
  completedOn      DateTime? @map("completed_on") @db.Date
  documentFileId   String?   @map("document_file_id") @db.Uuid
  recurrenceMonths Int?      @map("recurrence_months")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  property         Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  documentFile     File?     @relation(fields: [documentFileId], references: [id], onDelete: SetNull)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([propertyId], map: "idx_compliance_items_property_id")
  @@index([workspaceId, dueOn], map: "idx_compliance_items_workspace")
  @@map("compliance_items")
}

model Reminder {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  subjectType      String    @map("subject_type")
  subjectId        String    @map("subject_id") @db.Uuid
  dueOn            DateTime  @map("due_on") @db.Date
  leadDays         Int[]     @default([60, 30, 7]) @map("lead_days")
  lastNotifiedLead Int?      @map("last_notified_lead")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([subjectType, subjectId])
  @@index([dueOn], map: "idx_reminders_due_on")
  @@index([workspaceId, dueOn], map: "idx_reminders_workspace")
  @@map("reminders")
}

// ---- 0007_notifications_and_jobs ----

model Notification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String
  title       String
  body        String?
  linkPath    String?   @map("link_path")
  dedupeKey   String?   @map("dedupe_key")
  readAt      DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_notifications_workspace")
  @@map("notifications")
}

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  type        String
  payload     Json      @default("{}")
  status      String    @default("pending")
  runAt       DateTime  @default(now()) @map("run_at") @db.Timestamptz(6)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, runAt], map: "idx_jobs_status_run_at")
  @@index([workspaceId, status, runAt], map: "idx_jobs_workspace")
  @@map("jobs")
}

// ---- 0008_generated_documents ----

model GeneratedDocument {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String     @map("workspace_id") @db.Uuid
  docType         String     @map("doc_type")
  templateVersion String     @map("template_version")
  subjectType     String     @map("subject_type")
  subjectId       String     @map("subject_id") @db.Uuid
  fileId          String     @map("file_id") @db.Uuid
  inputSnapshot   Json       @map("input_snapshot")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  file            File       @relation(fields: [fileId], references: [id], onDelete: Restrict)
  contracts       Contract[]
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], map: "uq_generated_documents_id_workspace")
  @@index([subjectType, subjectId], map: "idx_generated_documents_subject")
  @@index([fileId], map: "idx_generated_documents_file_id")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_generated_documents_workspace")
  @@map("generated_documents")
}

model UserSettings {
  userId               String   @id @map("user_id") @db.Uuid
  defaultLeadDays      Int[]    @default([60, 30, 7]) @map("default_lead_days")
  rentOverdueGraceDays Int      @default(3) @map("rent_overdue_grace_days")
  emailEnabled         Boolean  @default(true) @map("email_enabled")
  clausePetsDefault    Boolean  @default(false) @map("clause_pets_default")
  clauseGardenDefault  Boolean  @default(false) @map("clause_garden_default")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ---- 0012_contractors ----

model Contractor {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String             @map("workspace_id") @db.Uuid
  businessName       String             @map("business_name")
  contactName        String?            @map("contact_name")
  trade              String
  email              String?            @db.Citext
  phone              String?
  website            String?
  serviceArea        String?            @map("service_area")
  registrationNumber String?            @map("registration_number")
  notes              String?
  status             String             @default("active")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  reviews            ContractorReview[]
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([id, workspaceId], map: "uq_contractors_id_workspace")
  @@index([status, trade], map: "idx_contractors_status_trade")
  @@index([workspaceId, status, trade], map: "idx_contractors_workspace")
  @@map("contractors")
}

model ContractorReview {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String     @map("workspace_id") @db.Uuid
  contractorId    String     @map("contractor_id") @db.Uuid
  rating          Int
  reviewedOn      DateTime   @default(now()) @map("reviewed_on") @db.Date
  workDescription String     @map("work_description")
  comments        String?
  wouldHireAgain  Boolean    @default(true) @map("would_hire_again")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([contractorId, reviewedOn(sort: Desc)], map: "idx_contractor_reviews_contractor_reviewed")
  @@index([workspaceId, reviewedOn(sort: Desc)], map: "idx_contractor_reviews_workspace")
  @@map("contractor_reviews")
}
