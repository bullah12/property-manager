# --- Database (local Supabase stack: npm run db:start) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Supabase (local stack via docker/docker-compose.yml) ---
# These are the well-known supabase-demo LOCAL DEV keys (JWT secret
# "super-secret-jwt-token-with-at-least-32-characters-long"). They are not
# secrets. Replace all three when pointing at a hosted Supabase project.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTk4MzgxMjk5Nn0.hYbst7AOsMaEUXOk1b6MqUgf8QOUTuw4Q051bbbcK4Q
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxOTgzODEyOTk2fQ.qDqDh683ruEw4ZGQ4tw4qDaJJJMxznu7uQJ9sm91uQE

# --- App ---
APP_URL=http://localhost:3000

# --- Email (Resend). Empty key = dev mock mode: payloads are logged, not sent. ---
RESEND_API_KEY=
EMAIL_FROM="Property Manager <notifications@example.com>"

# --- Internal cron routes (Phase 8) ---
CRON_SECRET=local-dev-cron-secret

# --- Seeded admin login (db:seed, Phase 1) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-password-123

# --- Local proof runs only: honour ?today= test clock on the scan route even
# in a production build. Leave unset in any real deployment. ---
ALLOW_TEST_CLOCK=
